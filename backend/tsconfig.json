{
  "compilerOptions": {
    "target": "ES2022",

    // "module": "NodeNext",
    // "moduleResolution": "NodeNext",

    "module": "ESNext",
    "moduleResolution": "Bundler",

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "resolveJsonModule": true,

    "skipLibCheck": true,

    "sourceMap": true,

    "declaration": true,

    "forceConsistentCasingInFileNames": true
  },

  "include": ["src"]
}
